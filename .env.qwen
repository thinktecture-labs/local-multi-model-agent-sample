# ============================================================
# Qwen 3.5 Model Configuration — Testing Override
# ============================================================
# Source this AFTER .env to override model paths for Qwen 3.5 testing.
# Usage: cp .env.qwen .env.local  (then start servers normally)
#
# Qwen 3.5 model family (June 2025):
#   - Qwen3.5-2B (Q8_0):   intent classification, query rewriting, formatting
#   - Qwen3.5-4B (Q4_K_M): tool calling (native), RAG synthesis, vision
#   - embeddinggemma:       kept as-is (98% MRR, no Qwen embedding GGUF)
#
# Download models first: bash scripts/download_qwen_models.sh
# GGUFs from: https://huggingface.co/unsloth/Qwen3.5-{2B,4B}-GGUF
# ============================================================

# ─── Qwen GGUFs ─────────────────────────────────────────────────────────────
# Inference (Thinker): Qwen3.5-4B for everything — same model as Doer + Vision
# Simplifies architecture to one text model + one embedding model
INFERENCE_GGUF=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf
INFERENCE_GGUF_FT=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf

# Function calling (Doer): Qwen3.5-4B for tool routing.
# Qwen 3.5 has NATIVE function calling — no fine-tuning needed for tool routing
FUNCTION_GGUF=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf
FUNCTION_GGUF_FT=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf

# Embedding: keep embeddinggemma (no Qwen GGUF embedding model available)
# EMBEDDING_GGUF=  (unchanged, inherited from .env)
# EMBEDDING_GGUF_FT=  (unchanged, inherited from .env)

# Vision: Qwen3.5-4B with mmproj (same GGUF as function calling)
VISION_GGUF=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf
VISION_MMPROJ=models/qwen3.5-4b/mmproj-F16.gguf

# ─── Model names (logging only — llama-server ignores these) ────────────────
INFERENCE_MODEL=qwen3.5-4b
FUNCTION_MODEL=qwen3.5-4b
# EMBEDDING_MODEL=  (unchanged)
VISION_MODEL=qwen3.5-4b-vision
