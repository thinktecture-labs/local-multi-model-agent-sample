@startuml C4_Level4_HybridRouting_Local
title Local Path

' TT brand palette
!$TT_RED       = "#ff584f"
!$TT_RED_PALE  = "#ffd5d2"
!$TT_BLUE      = "#3d6fb4"
!$TT_BLUE_PALE = "#e6eef7"
!$TT_BLACK     = "#22242d"
!$TT_GRAY      = "#868686"
!$TT_CREAM     = "#f4f5f8"
!$TT_CREAM_DK  = "#eceef2"
!$TT_WHITE     = "#ffffff"

skinparam BackgroundColor transparent
skinparam DefaultFontColor $TT_BLACK
skinparam ArrowColor $TT_BLACK
skinparam ActivityBackgroundColor $TT_WHITE
skinparam ActivityBorderColor $TT_BLACK
skinparam ActivityDiamondBackgroundColor $TT_WHITE
skinparam ActivityDiamondBorderColor $TT_BLACK
skinparam ActivityFontColor $TT_BLACK

start

:POST /query;
:agent.process(query)\n<i>Full local pipeline</i>;<<$TT_BLUE_PALE>>
:AgentResponse;

:ConfidenceRouter\n8-factor heuristic scoring;

if (score >= 0.6?) then (yes)
    :Return response\nconfidence: 0.85;<<$TT_BLUE_PALE>>
    stop
else (no)
    :Return response\n+ should_escalate: true\n+ confidence: 0.42;<<$TT_CREAM_DK>>
    :Observatory UI\nshows escalation banner;
    stop
endif

@enduml
