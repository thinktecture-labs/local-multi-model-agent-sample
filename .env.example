# ============================================================
# Local Gemma Agent — Configuration
# ============================================================
# Copy to .env:  cp .env.example .env  (done automatically by setup.sh)
# Override locally without touching .env:  create .env.local
# All paths are relative to the repo root.
# ============================================================

# ─── llama-server binary ──────────────────────────────────────────────────────
LLAMA_SERVER=vendor/llama.cpp/build/bin/llama-server

# ─── Model GGUFs ──────────────────────────────────────────────────────────────
# Base models (pre fine-tuning, scenario-independent)
INFERENCE_GGUF=models/gemma3/gemma-3-1b-it-Q8_0.gguf
# Tool-calling model. Production uses Qwen 3.5-4B (fine-tuned per scenario).
# Set FUNCTION_GGUF to your base Qwen path or override per-scenario via scenarios/<name>.json.
FUNCTION_GGUF=models/qwen3.5-4b/Qwen3.5-4B-Q4_K_M.gguf
EMBEDDING_GGUF=models/embeddinggemma/embeddinggemma-300M-Q8_0.gguf
# Fine-tuned GGUFs are scenario-specific — paths come from scenarios/<name>.json
# e.g. gemma3-ft-<scenario>.gguf
# start_servers.sh reads them from the scenario JSON via SCENARIO env var.
# Vision: multimodal model (gemma3-4B with mmproj for image understanding)
VISION_GGUF=models/gemma3-4b/gemma-3-4b-it-Q4_K_M.gguf
VISION_MMPROJ=models/gemma3-4b/mmproj-model-f16.gguf

# ─── llama-server ports ───────────────────────────────────────────────────────
# Base models
INFERENCE_PORT=9090
FUNCTION_PORT=9091
EMBEDDING_PORT=9092
VISION_PORT=9093
# Fine-tuned models (dual-port swap — no vision, shared on 9093)
INFERENCE_PORT_FT=9094
FUNCTION_PORT_FT=9095
EMBEDDING_PORT_FT=9096

# ─── Model names (used by SmallLanguageModelClient in API request bodies) ─────────────────
# Note: llama-server ignores the model name in requests — any string works.
# These are used for logging/identification only.
INFERENCE_MODEL=gemma3-ft
FUNCTION_MODEL=qwen3.5-4b-toolcalling-ft
EMBEDDING_MODEL=embeddinggemma
VISION_MODEL=gemma3-4b-vision

# ─── Agent configuration ─────────────────────────────────────────────────────
# Timeout for model API calls in seconds (per request)
AGENT_TIMEOUT=30.0
# Maximum rows returned by SQL queries
SQL_MAX_ROWS=200
# Maximum documents returned by vector search
VECTOR_SEARCH_MAX_K=10

# ─── Generation temperatures ─────────────────────────────────────────────────
# Lower = more deterministic, less hallucination. Higher = more creative.
TOOL_FORMAT_TEMPERATURE=0.2
DIRECT_ANSWER_TEMPERATURE=0.3

# ─── Voice (whisper.cpp STT + Piper TTS — optional) ─────────────────────────
# Voice features are enabled when whisper-server binary and model are present.
# Run: bash scripts/setup_voice.sh to download/build everything.
WHISPER_SERVER=vendor/whisper.cpp/build/bin/whisper-server
WHISPER_MODEL=models/whisper/ggml-medium.bin
WHISPER_PORT=9097
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_VOICE_DE=de_DE-thorsten-high
PIPER_VOICES_DIR=models/piper
# Stage-demo punchline: regex-triggered canned voice responses bypass the agent
# for known triggers (used at the keynote climax). Off by default for forks.
# Set to 1 to re-enable. Trigger list lives in src/server/voice_routes.py.
VOICE_CANNED_RESPONSES=0

# ─── OCR (GLM-OCR on llama-server — optional, upload-time only) ──────────────
# Extracts text + tables from scanned/image PDFs using GLM-OCR vision model.
# Run: bash scripts/setup_ocr.sh to download the model.
# OCR features are auto-detected when the server is running on OCR_PORT.
OCR_GGUF=models/glm-ocr/GLM-OCR-Q8_0.gguf
OCR_MMPROJ=models/glm-ocr/mmproj-GLM-OCR-Q8_0.gguf
OCR_PORT=9098

# ─── CORS (comma-separated allowed origins) ──────────────────────────────────
# Default: localhost only. Add your ngrok URL when exposing remotely.
# Example: CORS_ORIGINS=http://localhost:8000,https://your-domain.ngrok.io
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Cloud comparison (optional — set OPENAI_API_KEY to enable) ─────────────
# Enables the /compare, /escalate, and /query/compare-all endpoints.
# Pricing: https://developers.openai.com/api/docs/pricing (GPT-5.4 standard tier)
# OPENAI_API_KEY=sk-...
# OPENAI_COMPARE_MODEL=gpt-5.4
# CLOUD_INPUT_COST_PER_1M=2.50
# CLOUD_OUTPUT_COST_PER_1M=15.00
